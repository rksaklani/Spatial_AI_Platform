# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-this-password

# Valkey Configuration
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=change-this-password
VALKEY_MAX_CONNECTIONS=50
VALKEY_SOCKET_TIMEOUT=5
VALKEY_CONNECT_TIMEOUT=5

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-password

# JWT Configuration
JWT_SECRET_KEY=change-this-secret-key-to-a-random-string

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://yourdomain.com"]

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Environment
ENVIRONMENT=production
