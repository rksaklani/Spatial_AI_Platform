# MongoDB Configuration
# For local development (no auth):
# MONGODB_URL=mongodb://localhost:27017
# For Docker Compose (with auth):
MONGODB_URL=mongodb://admin:admin123@localhost:27017/spatial_ai_platform?authSource=admin
# For MongoDB Atlas:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/spatial_ai_platform?retryWrites=true&w=majority
DATABASE_NAME=spatial_ai_platform

# Valkey Configuration
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=
VALKEY_MAX_CONNECTIONS=50
VALKEY_SOCKET_TIMEOUT=5
VALKEY_CONNECT_TIMEOUT=5

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery Configuration
CELERY_BROKER_URL=valkey://localhost:6379/0
CELERY_RESULT_BACKEND=valkey://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=development

# Gaussian Splatting Configuration
# Set to true to force CPU mode for Gaussian Splatting training (disables GPU)
# Useful when GPU is reserved for other tasks or when debugging
GAUSSIAN_SPLATTING_FORCE_CPU=false
